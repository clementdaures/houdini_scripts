from pxr import Sdf, Usd

node = hou.pwd()
ctrl = hou.node("..")

sources = [s.strip() for s in ctrl.parm("source_paths").eval().split()]
stage = node.editableStage()

def isolate_paths(prim, keep_list):
    """
    Recursively deactivates prims that are not in the keep_list 
    or ancestors of the keep_list.
    """
    path_str = str(prim.GetPath())
    
    is_target = path_str in keep_list
    
    is_ancestor = any(k.startswith(path_str + "/") for k in keep_list)
    
    if is_target:
        prim.SetActive(True)
    elif is_ancestor:
        prim.SetActive(True)
        for child in prim.GetChildren():
            isolate_paths(child, keep_list)
    else:
        prim.SetActive(False)

if sources:
    root_prims = stage.GetPseudoRoot().GetChildren()
    for root in root_prims:
        isolate_paths(root, sources)
